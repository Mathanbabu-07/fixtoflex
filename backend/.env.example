# FixToFlex Backend Configuration Template

# Server settings
PORT=8000
HOST=0.0.0.0
APP_ENV=production
FRONTEND_URL=https://your-vercel-domain-here.vercel.app

# Additional CORS origins (comma-separated list of extra frontend domains to permit, e.g. Vercel preview environments)
ADDITIONAL_CORS_ORIGINS=https://your-vercel-domain-here.vercel.app,https://another-domain.com

# Cookie Configuration for Cross-Origin Production Setup (Vercel and Render domains are cross-site)
# When APP_ENV=production, these are automatically set to secure=True and samesite="none" by the server
COOKIE_SECURE=True
COOKIE_SAMESITE=none

# Supabase Database configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-goes-here

# JWT configuration for internal session tokens
JWT_SECRET=generate-a-long-random-string-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# LinkedIn Developer Application Credentials (for LinkedIn Login & OAuth flow)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://your-vercel-domain-here.vercel.app/auth/linkedin/callback

# Scrape.do API keys (used as fallback for LinkedIn scraping)
SCRAPEDO_API_KEY=your-scrape-do-api-key
SCRAPEDO1_API_KEY=your-scrapedo1-api-key
SCRAPEDO_BASE_URL=http://api.scrape.do

# Google Gemini API Configuration (Gemini 3.1 Flash Lite models)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API1_KEY=your-gemini-api1-key
GEMINI_INTERVIEW_API_KEY=your-gemini-interview-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# Jina AI Reader Configuration (Primary LinkedIn & Portfolio scraper)
JINA_API_KEY=your-jina-ai-api-key-here
