# Server settings
PORT=8000
HOST=127.0.0.1
FRONTEND_URL=http://localhost:3001

# Supabase configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-goes-here

# JWT configuration for internal session tokens (future LinkedIn login mapping)
JWT_SECRET=generate-a-long-random-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LinkedIn Developer Application Credentials
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3001/auth/linkedin/callback
# Scrape.do API keys
SCRAPEDO_API_KEY=your-scrape-do-api-key
SCRAPEDO_BASE_URL=http://api.scrape.do

# Google Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
